{
  "Routes": [
    {
      "DownstreamPathTemplate": "/api/Patients",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "patientservice-api",
          "Port": 8080
        }
      ],
      "UpstreamPathTemplate": "/patients",
      "UpstreamHttpMethod": [ "GET", "POST" ],
      "AddHeadersToRequest": {
        "Authorization": "{Authorization}"
      }
    },
    {
      "DownstreamPathTemplate": "/api/Patients/{id}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "patientservice-api",
          "Port": 8080
        }
      ],
      "UpstreamPathTemplate": "/patients/{id}",
      "UpstreamHttpMethod": [ "GET", "PUT" ],
      "AddHeadersToRequest": {
        "Authorization": "{Authorization}"
      }
    },
    {
      "DownstreamPathTemplate": "/api/Notes/patient/{id}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "noteservice-api",
          "Port": 8080
        }
      ],
      "UpstreamPathTemplate": "/notes/patient/{id}",
      "UpstreamHttpMethod": [ "GET" ],
      "AddHeadersToRequest": {
        "Authorization": "{Authorization}"
      }
    },
    {
      "DownstreamPathTemplate": "/api/Notes",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "noteservice-api",
          "Port": 8080
        }
      ],
      "UpstreamPathTemplate": "/notes",
      "UpstreamHttpMethod": [ "POST" ],
      "AddHeadersToRequest": {
        "Authorization": "{Authorization}"
      }
    },
    {
      "DownstreamPathTemplate": "/api/Assessment/{id}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "assessmentservice-api",
          "Port": 8080
        }
      ],
      "UpstreamPathTemplate": "/assessment/{id}",
      "UpstreamHttpMethod": [ "GET" ],
      "AddHeadersToRequest": {
        "Authorization": "{Authorization}"
      }
    }
  ],
  "GlobalConfiguration": {
    "BaseUrl": "http://gatewayservice:8080"
  }
}